import React, { useState, useEffect } from 'react';
import { supabase } from '../src/lib/supabase';

const ResetPasswordPage: React.FC = () => {
  const [password, setPassword] = useState('');
  const [message, setMessage] = useState('');
  const [error, setError] = useState('');

  useEffect(() => {
    // Tangkap token dari URL
    const hash = window.location.hash;
    console.log('Hash:', hash);
  }, []);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    const { error } = await supabase.auth.updateUser({ password });
    
    if (error) {
      setError(error.message);
    } else {
      setMessage('Password berhasil direset! Silakan login.');
    }
  };

  return (
    <div className="min-h-screen flex items-center justify-center">
      <form onSubmit={handleSubmit} className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
        <h2 className="text-2xl font-black mb-6">Reset Password</h2>
        {message && <div className="bg-emerald-50 text-emerald-600 p-3 rounded-xl mb-4">{message}</div>}
        {error && <div className="bg-red-50 text-red-600 p-3 rounded-xl mb-4">{error}</div>}
        
        <input
          type="password"
          value={password}
          onChange={(e) => setPassword(e.target.value)}
          placeholder="Password baru"
          className="w-full p-4 bg-slate-50 rounded-xl mb-4"
          required
        />
        
        <button type="submit" className="w-full py-4 bg-blue-600 text-white rounded-xl font-bold">
          Update Password
        </button>
      </form>
    </div>
  );
};

export default ResetPasswordPage;