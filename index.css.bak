@tailwind base;
@tailwind components;
@tailwind utilities;

/* Tambahkan CSS global Anda di sini */
/* Perbaikan QR Scanner - Rapi dan Fullscreen */
#qr-scanner-container {
  width: 100%;
  height: 100%;
  position: relative;
  background: #000;
}

#qr-scanner-container video {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

/* Hilangkan border putih yang gak perlu */
#qr-scanner-container div {
  border: none !important;
}

/* Kotak scan lebih rapi */
.qr-scanner-box {
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.6);
}